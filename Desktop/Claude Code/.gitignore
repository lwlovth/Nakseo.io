node_modules/
jspm_packages/
# 용량이 너무 크고 npm install로 언제든 다시 받을 수 있습니다.

# 3. 빌드 결과물 (GitHub Pages 배포 시 dist 폴더는 제외될 수 있음)
dist/
build/
